Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Canonical domain (production only; localhost is left untouched) ---
  # Force HTTPS.
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Drop the www. prefix.
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # --- SEO endpoints ---
  RewriteRule ^robots\.txt$ robots.php [L]
  RewriteRule ^sitemap\.xml$ sitemap.php [L]

  # --- Admin entry ---
  RewriteRule ^sanchalak/?$ sanchalak/index.php [L]
</IfModule>

# robots.txt and sitemap.xml are generated by PHP — make sure they are
# served as their real content types even though the URLs end in .txt/.xml.
<IfModule mod_headers.c>
  <FilesMatch "^(robots\.php|sitemap\.php)$">
    Header set X-Robots-Tag "all"
  </FilesMatch>
</IfModule>
